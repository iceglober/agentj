{
  "name": "coder",
  "private": true,
  "description": "A coding agent that prefers computation to inference and actively manages its context budget. Self-contained; multi-provider via the Vercel AI SDK.",
  "license": "MIT",
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bun run --filter='*' test",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "bun run --filter='*' lint",
    "coder": "bun bin/coder"
  },
  "dependencies": {
    "coder-tui": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22",
    "typescript": "^5.7.3"
  }
}
