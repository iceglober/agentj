{
  "name": "@glrs-dev/aj",
  "version": "0.1.0-next.31",
  "private": false,
  "description": "agentj: a simple, effective terminal coding agent. The sole product lives in core/; this file carries the root Bun entrypoints.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceglober/agentj.git"
  },
  "bugs": "https://github.com/iceglober/agentj/issues",
  "homepage": "https://github.com/iceglober/agentj#readme",
  "files": [
    "bin",
    "core",
    "README.md",
    "LICENSE",
    "!core/**/*.test.ts",
    "!core/eval/results",
    "!core/eval/traj",
    "!core/lib/tools/edit/benchmarks"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "tag": "next"
  },
  "bin": {
    "agentj": "bin/agentj",
    "aj": "bin/aj"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun core/agent-loop.ts",
    "agentj": "bun core/agent-loop.ts",
    "test": "bun test core docs",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "docs": "bun docs/generate.ts",
    "eval": "bun core/eval/run.ts",
    "eval:report": "bun core/eval/report.ts",
    "eval:selfcheck": "bun core/eval/run.ts --selfcheck",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:next": "bun publish --access public --tag next"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.2.24",
    "@types/node": "^24.0.15",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ai-sdk/azure": "^4.0.11",
    "@crosscopy/clipboard": "^0.3.6",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "ai": "^7.0.22",
    "bash-tool": "^1.3.17",
    "cmd-ts": "^0.15.0",
    "microsandbox": "^0.6.6",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  }
}
