{
  "name": "agentj",
  "private": true,
  "description": "agentj: a simple, effective terminal coding agent. The sole product lives in core/; this file carries the root Bun entrypoints.",
  "license": "MIT",
  "bin": {
    "agentj": "bin/agentj",
    "aj": "bin/aj"
  },
  "packageManager": "bun@1.2.0",
  "scripts": {
    "agentj": "bun core/agent-loop.ts",
    "test": "bun test core",
    "typecheck": "tsc --noEmit",
    "eval": "bun core/eval/run.ts",
    "eval:report": "bun core/eval/report.ts",
    "eval:selfcheck": "bun core/eval/run.ts --selfcheck",
    "agentj:secrets": "bun core/secrets-cli.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.2.24",
    "@types/node": "^24.0.15",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ai-sdk/azure": "^4.0.11",
    "ai": "^7.0.22",
    "bash-tool": "^1.3.17",
    "cmd-ts": "^0.15.0",
    "microsandbox": "^0.6.6",
    "prompts": "^2.4.2",
    "zod": "^4.4.3",
    "@napi-rs/keyring": "^1.3.0",
    "@opentelemetry/api": "^1.9.1"
  }
}
