{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agentj",
  "version": "0.1.0",
  "identifier": "io.iceglobe.agentj.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "agentj",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
