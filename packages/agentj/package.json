{
  "name": "agentj",
  "version": "0.0.0",
  "private": true,
  "description": "agentj: a simple, effective terminal coding agent. Built-in file/exec tools + MCP, multi-provider via the Vercel AI SDK.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "agentj": "./src/index.ts",
    "aj": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "echo 'no linter configured yet'"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4",
    "@ai-sdk/google-vertex": "^5",
    "@ai-sdk/openai-compatible": "^3",
    "@modelcontextprotocol/sdk": "^1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ai": "^7",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22",
    "typescript": "^5"
  },
  "license": "MIT"
}
