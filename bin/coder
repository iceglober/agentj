#!/usr/bin/env bun
// coder — binary entry point.
//
// Launches the TUI client (the host-side cockpit). The agent server runs separately,
// sandboxed per-worktree; the client connects to it over HTTP/SSE. See docs/PLAN.md.
import { main } from "coder-tui";

main(process.argv.slice(2)).catch((err) => {
  console.error(err instanceof Error ? err.stack ?? err.message : String(err));
  process.exit(1);
});
