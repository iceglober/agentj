#!/usr/bin/env bash
# aj — short alias for the agentj launcher (resolves symlinks so it works from your PATH).
set -euo pipefail
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ $src != /* ]] && src="$dir/$src"
done
exec "$(cd -P "$(dirname "$src")" && pwd)/agentj" "$@"
