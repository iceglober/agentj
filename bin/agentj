#!/usr/bin/env bash
# agentj — launches the Rust (ratatui) build in agentj-rs/.
# On first run (or after `cargo clean`) it builds the release binary, then execs it.
# Resolves symlinks so this can be symlinked onto your PATH and run from any directory.
set -euo pipefail
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ $src != /* ]] && src="$dir/$src"
done
here="$(cd -P "$(dirname "$src")/.." && pwd)"
bin="$here/agentj-rs/target/release/agentj"
# Rebuild when the binary is missing OR any source has changed since it was last built, so `aj` run
# from any directory always uses the latest code. `find -newer` is a cheap freshness check; when
# nothing changed it's a no-op and we exec straight through.
if [ ! -x "$bin" ] || [ -n "$(find "$here/agentj-rs/src" "$here/agentj-rs/Cargo.toml" "$here/agentj-rs/Cargo.lock" -newer "$bin" 2>/dev/null)" ]; then
  echo "agentj: building the release binary…" >&2
  cargo build --release --manifest-path "$here/agentj-rs/Cargo.toml" >&2
fi
exec "$bin" "$@"
