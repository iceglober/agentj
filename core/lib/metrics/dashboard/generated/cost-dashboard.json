{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum(rate(agentj_llm_tokens_no_cache_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval]))",
          "legendFormat": "gpt-5.6-sol no cache",
          "refId": "A"
        },
        {
          "expr": "sum(rate(agentj_llm_tokens_cache_read_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval]))",
          "legendFormat": "gpt-5.6-sol cache read",
          "refId": "B"
        },
        {
          "expr": "sum(rate(agentj_llm_tokens_cache_write_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval]))",
          "legendFormat": "gpt-5.6-sol cache write",
          "refId": "C"
        },
        {
          "expr": "sum(rate(agentj_llm_tokens_output_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval]))",
          "legendFormat": "gpt-5.6-sol output",
          "refId": "D"
        }
      ],
      "title": "Token throughput by model",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "(sum(rate(agentj_llm_tokens_no_cache_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval])) * 1.25 / 1000000 + sum(rate(agentj_llm_tokens_cache_read_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval])) * 1.25 / 1000000 + sum(rate(agentj_llm_tokens_cache_write_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval])) * 1.25 / 1000000 + sum(rate(agentj_llm_tokens_output_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval])) * 10 / 1000000) * 3600",
          "legendFormat": "gpt-5.6-sol",
          "refId": "A"
        }
      ],
      "title": "Priced tokens by model",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum(rate(agentj_llm_tokens_input_long_context_tokens_total{model=\"gpt-5.6-sol\"}[$__rate_interval])) * 1.25 * 2 / 1000000 * 3600",
          "legendFormat": "gpt-5.6-sol 2x input tier",
          "refId": "A"
        }
      ],
      "title": "Long-context input tier (>272k tokens)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 41,
  "tags": ["agentj", "otel", "cost"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "AgentJ cost dashboard",
  "uid": "agentj-cost",
  "version": 1
}
